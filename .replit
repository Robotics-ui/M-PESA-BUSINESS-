modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Canvas"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "M-PESA Business Loans"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Canvas"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8081 BASE_PATH=/__mockup pnpm --filter @workspace/mockup-sandbox run dev"
waitForPort = 8081

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "M-PESA Business Loans"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=22025 BASE_PATH=/ pnpm --filter @workspace/mpesa-business-loans run dev"
waitForPort = 22025

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
